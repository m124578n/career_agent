# 複製成 .env 並填入實際值（.env 已被 .gitignore 擋掉）
MONGO_URI=mongodb://localhost:27017
MONGO_DB=job_tracker

# 日誌層級：DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# CORS 允許來源（逗號分隔）；部署時加上前端正式網址
ALLOWED_ORIGINS=http://localhost:5173

# Google 登入：留空 → 停用驗證（本機開發）；正式環境填 OAuth Client ID
GOOGLE_CLIENT_ID=
DAILY_CALL_LIMIT=50
# 可看全站 token 用量的 admin（逗號分隔）
ADMIN_EMAILS=

# LLM provider：openrouter | azure | anthropic
LLM_PROVIDER=openrouter

# OpenRouter（免費模型，額度易被限流）
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free

# Azure OpenAI（用這個就把 LLM_PROVIDER 設成 azure）
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Anthropic（可選，原生 structured outputs）
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
